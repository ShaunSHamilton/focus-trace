{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Trace",
  "version": "1.1.0",
  "identifier": "com.focus-trace.app",
  "build": {
    "beforeDevCommand": "bun run --bun dev",
    "beforeBuildCommand": "bun run --bun build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Focus Trace",
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Focus Trace",
  "version": "1.3.0",
  "identifier": "com.focus-trace.app",
  "build": {
    "beforeDevCommand": "bun run --bun dev",
    "beforeBuildCommand": "bun run --bun build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../frontend/dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "title": "Focus Trace",
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ShaunSHamilton/focus-trace/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgxNUU1NTU4MUJGMEEwOTcKUldTWG9QQWJXRlZlZ1dvdmQyOVZYNm0vaTlEMDNZdlJacjBGbGVBc3JFT09jWHFaMlZocERtM2UK"
    }
  }
}
